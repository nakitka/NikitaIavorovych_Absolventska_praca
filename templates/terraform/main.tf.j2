# Terraform configuration for Gitea Infrastructure
# Generated by Gitea Infrastructure Deployment

# Provider configuration
provider "vsphere" {
  vsphere_server       = var.vsphere_server
  user                 = var.vsphere_user
  password             = var.vsphere_password
  allow_unverified_ssl = true
}

# Data sources
data "vsphere_datacenter" "dc" {
  name = var.datacenter
}

data "vsphere_compute_cluster" "cluster" {
  name          = var.cluster
  datacenter_id = data.vsphere_datacenter.dc.id
}

data "vsphere_datastore" "datastore" {
  name          = var.datastore
  datacenter_id = data.vsphere_datacenter.dc.id
}

{% if infrastructure.backup.enabled and infrastructure.backup.datastore %}
# Separate datastore for backup VM
data "vsphere_datastore" "backup_datastore" {
  name          = "{{ infrastructure.backup.datastore }}"
  datacenter_id = data.vsphere_datacenter.dc.id
}
{% endif %}

data "vsphere_network" "network" {
  name          = var.network
  datacenter_id = data.vsphere_datacenter.dc.id
}

data "vsphere_virtual_machine" "haproxy_template" {
  name          = "{{ template_folder_relative }}/{{ constants.TEMPLATE_NAMES.haproxy }}"
  datacenter_id = data.vsphere_datacenter.dc.id
}

data "vsphere_virtual_machine" "kubernetes_template" {
  name          = "{{ template_folder_relative }}/{{ constants.TEMPLATE_NAMES.kubernetes }}"
  datacenter_id = data.vsphere_datacenter.dc.id
}

data "vsphere_virtual_machine" "glusterfs_template" {
  name          = "{{ template_folder_relative }}/{{ constants.TEMPLATE_NAMES.glusterfs }}"
  datacenter_id = data.vsphere_datacenter.dc.id
}

# Reference existing resource pool from config
data "vsphere_resource_pool" "pool" {
  name          = "{{ vsphere.cluster }}/{{ vsphere.resource_pool }}"
  datacenter_id = data.vsphere_datacenter.dc.id
}

# VM folder - use data source if folder already exists
# This prevents errors when the folder pre-exists in vSphere
data "vsphere_folder" "existing_vm_folder" {
  path = "{{ vsphere.vm_folder }}"
}

# Locals for reusable values
locals {
  # Use relative path for VM folder - Terraform expects path relative to datacenter
  vm_folder_path = "{{ vm_folder_relative }}"
  ssh_public_key = file("${path.module}/../credentials/ssh_key.pub")
}

# HAProxy VMs
{% for i in range(infrastructure.haproxy.count) %}
resource "vsphere_virtual_machine" "haproxy_{{ i + 1 }}" {
  name             = "haproxy-{{ i + 1 }}"
  resource_pool_id = data.vsphere_resource_pool.pool.id
  datastore_id     = data.vsphere_datastore.datastore.id
  folder           = local.vm_folder_path

  num_cpus = {{ infrastructure.haproxy.cpu }}
  memory   = {{ infrastructure.haproxy.ram_gb * 1024 }}
  guest_id = data.vsphere_virtual_machine.haproxy_template.guest_id

  # Don't wait for guest - cloud-init handles network config
  wait_for_guest_net_timeout = 0
  wait_for_guest_ip_timeout  = 0

  network_interface {
    network_id   = data.vsphere_network.network.id
    adapter_type = data.vsphere_virtual_machine.haproxy_template.network_interface_types[0]
  }

  disk {
    label            = "disk0"
    size             = {{ infrastructure.haproxy.disk_gb }}
    thin_provisioned = true
  }

  clone {
    template_uuid = data.vsphere_virtual_machine.haproxy_template.id
  }

  extra_config = {
    "guestinfo.userdata" = base64encode(templatefile("${path.module}/cloud-init.yaml", {
      hostname       = "haproxy-{{ i + 1 }}"
      ssh_public_key = local.ssh_public_key
      ipv4_address   = "{{ haproxy_ips[i] }}"
      ipv4_netmask   = "{{ network.subnet_mask }}"
      ipv4_gateway   = "{{ network.gateway }}"
      dns_servers    = "{{ network.dns_servers|join(' ') }}"
    }))
    "guestinfo.userdata.encoding" = "base64"
  }

  lifecycle {
    ignore_changes = [tags]
  }
}
{% endfor %}

# Kubernetes Master VMs
{% for i in range(infrastructure.control_plane.count) %}
resource "vsphere_virtual_machine" "master_{{ i + 1 }}" {
  name             = "master-{{ i + 1 }}"
  resource_pool_id = data.vsphere_resource_pool.pool.id
  datastore_id     = data.vsphere_datastore.datastore.id
  folder           = local.vm_folder_path

  num_cpus = {{ infrastructure.control_plane.cpu }}
  memory   = {{ infrastructure.control_plane.ram_gb * 1024 }}
  guest_id = data.vsphere_virtual_machine.kubernetes_template.guest_id

  # Don't wait for guest - cloud-init handles network config
  wait_for_guest_net_timeout = 0
  wait_for_guest_ip_timeout  = 0

  network_interface {
    network_id   = data.vsphere_network.network.id
    adapter_type = data.vsphere_virtual_machine.kubernetes_template.network_interface_types[0]
  }

  disk {
    label            = "disk0"
    size             = {{ infrastructure.control_plane.disk_gb }}
    thin_provisioned = true
  }

  clone {
    template_uuid = data.vsphere_virtual_machine.kubernetes_template.id
  }

  extra_config = {
    "guestinfo.userdata" = base64encode(templatefile("${path.module}/cloud-init.yaml", {
      hostname       = "master-{{ i + 1 }}"
      ssh_public_key = local.ssh_public_key
      ipv4_address   = "{{ master_ips[i] }}"
      ipv4_netmask   = "{{ network.subnet_mask }}"
      ipv4_gateway   = "{{ network.gateway }}"
      dns_servers    = "{{ network.dns_servers|join(' ') }}"
    }))
    "guestinfo.userdata.encoding" = "base64"
  }

  lifecycle {
    ignore_changes = [tags]
  }
}
{% endfor %}

# Kubernetes Worker VMs (Batch 2 - waits for Masters to complete)
{% for i in range(infrastructure.workers.count) %}
resource "vsphere_virtual_machine" "worker_{{ i + 1 }}" {
  name             = "worker-{{ i + 1 }}"
  resource_pool_id = data.vsphere_resource_pool.pool.id
  datastore_id     = data.vsphere_datastore.datastore.id
  folder           = local.vm_folder_path

  num_cpus = {{ infrastructure.workers.cpu }}
  memory   = {{ infrastructure.workers.ram_gb * 1024 }}
  guest_id = data.vsphere_virtual_machine.kubernetes_template.guest_id

  # Don't wait for guest - cloud-init handles network config
  wait_for_guest_net_timeout = 0
  wait_for_guest_ip_timeout  = 0

  network_interface {
    network_id   = data.vsphere_network.network.id
    adapter_type = data.vsphere_virtual_machine.kubernetes_template.network_interface_types[0]
  }

  disk {
    label            = "disk0"
    size             = {{ infrastructure.workers.disk_gb }}
    thin_provisioned = true
  }

  clone {
    template_uuid = data.vsphere_virtual_machine.kubernetes_template.id
  }

  extra_config = {
    "guestinfo.userdata" = base64encode(templatefile("${path.module}/cloud-init.yaml", {
      hostname       = "worker-{{ i + 1 }}"
      ssh_public_key = local.ssh_public_key
      ipv4_address   = "{{ worker_ips[i] }}"
      ipv4_netmask   = "{{ network.subnet_mask }}"
      ipv4_gateway   = "{{ network.gateway }}"
      dns_servers    = "{{ network.dns_servers|join(' ') }}"
    }))
    "guestinfo.userdata.encoding" = "base64"
  }

  # Wait for Batch 1 (HAProxy + Masters) to complete before creating Batch 2
  depends_on = [
    {% for j in range(infrastructure.haproxy.count) %}vsphere_virtual_machine.haproxy_{{ j + 1 }}{% if not loop.last %}, {% endif %}{% endfor %},
    {% for j in range(infrastructure.control_plane.count) %}vsphere_virtual_machine.master_{{ j + 1 }}{% if not loop.last %}, {% endif %}{% endfor %}
  ]

  lifecycle {
    ignore_changes = [tags]
  }
}
{% endfor %}

# GlusterFS VMs with additional data disk (Batch 2 - waits for Masters to complete)
{% for i in range(infrastructure.glusterfs.count) %}
resource "vsphere_virtual_machine" "glusterfs_{{ i + 1 }}" {
  name             = "glusterfs-{{ i + 1 }}"
  resource_pool_id = data.vsphere_resource_pool.pool.id
  datastore_id     = data.vsphere_datastore.datastore.id
  folder           = local.vm_folder_path

  num_cpus = {{ infrastructure.glusterfs.cpu }}
  memory   = {{ infrastructure.glusterfs.ram_gb * 1024 }}
  guest_id = data.vsphere_virtual_machine.glusterfs_template.guest_id

  # Don't wait for guest - cloud-init handles network config
  wait_for_guest_net_timeout = 0
  wait_for_guest_ip_timeout  = 0

  network_interface {
    network_id   = data.vsphere_network.network.id
    adapter_type = data.vsphere_virtual_machine.glusterfs_template.network_interface_types[0]
  }

  # OS disk
  disk {
    label            = "disk0"
    size             = {{ infrastructure.glusterfs.os_disk_gb }}
    thin_provisioned = true
    unit_number      = 0
  }

  # Data disk for GlusterFS
  disk {
    label            = "data-disk"
    size             = {{ infrastructure.glusterfs.data_disk_gb }}
    thin_provisioned = true
    unit_number      = 1
  }

  clone {
    template_uuid = data.vsphere_virtual_machine.glusterfs_template.id
  }

  extra_config = {
    "guestinfo.userdata" = base64encode(templatefile("${path.module}/cloud-init.yaml", {
      hostname       = "glusterfs-{{ i + 1 }}"
      ssh_public_key = local.ssh_public_key
      ipv4_address   = "{{ glusterfs_ips[i] }}"
      ipv4_netmask   = "{{ network.subnet_mask }}"
      ipv4_gateway   = "{{ network.gateway }}"
      dns_servers    = "{{ network.dns_servers|join(' ') }}"
    }))
    "guestinfo.userdata.encoding" = "base64"
  }

  # Wait for Batch 1 (HAProxy + Masters) to complete before creating Batch 2
  depends_on = [
    {% for j in range(infrastructure.haproxy.count) %}vsphere_virtual_machine.haproxy_{{ j + 1 }}{% if not loop.last %}, {% endif %}{% endfor %},
    {% for j in range(infrastructure.control_plane.count) %}vsphere_virtual_machine.master_{{ j + 1 }}{% if not loop.last %}, {% endif %}{% endfor %}
  ]

  lifecycle {
    ignore_changes = [tags]
  }
}
{% endfor %}

# Backup VM (optional, only if enabled)
{% if infrastructure.backup.enabled %}
{% for i in range(infrastructure.backup.count) %}
resource "vsphere_virtual_machine" "backup_{{ i + 1 }}" {
  name             = "backup-{{ i + 1 }}"
  resource_pool_id = data.vsphere_resource_pool.pool.id
  datastore_id     = {% if infrastructure.backup.datastore %}data.vsphere_datastore.backup_datastore.id{% else %}data.vsphere_datastore.datastore.id{% endif %}

  folder           = local.vm_folder_path

  num_cpus = {{ infrastructure.backup.cpu }}
  memory   = {{ infrastructure.backup.ram_gb * 1024 }}
  guest_id = data.vsphere_virtual_machine.kubernetes_template.guest_id

  # Don't wait for guest - cloud-init handles network config
  wait_for_guest_net_timeout = 0
  wait_for_guest_ip_timeout  = 0

  network_interface {
    network_id   = data.vsphere_network.network.id
    adapter_type = data.vsphere_virtual_machine.kubernetes_template.network_interface_types[0]
  }

  disk {
    label            = "disk0"
    size             = {{ infrastructure.backup.disk_gb }}
    thin_provisioned = true
  }

  clone {
    template_uuid = data.vsphere_virtual_machine.kubernetes_template.id
  }

  extra_config = {
    "guestinfo.userdata" = base64encode(templatefile("${path.module}/cloud-init.yaml", {
      hostname       = "backup-{{ i + 1 }}"
      ssh_public_key = local.ssh_public_key
      ipv4_address   = "{{ backup_ips[i] }}"
      ipv4_netmask   = "{{ network.subnet_mask }}"
      ipv4_gateway   = "{{ network.gateway }}"
      dns_servers    = "{{ network.dns_servers|join(' ') }}"
    }))
    "guestinfo.userdata.encoding" = "base64"
  }

  # Backup VM can be created in parallel with Batch 2
  depends_on = [
    {% for j in range(infrastructure.haproxy.count) %}vsphere_virtual_machine.haproxy_{{ j + 1 }}{% if not loop.last %}, {% endif %}{% endfor %},
    {% for j in range(infrastructure.control_plane.count) %}vsphere_virtual_machine.master_{{ j + 1 }}{% if not loop.last %}, {% endif %}{% endfor %}
  ]

  lifecycle {
    ignore_changes = [tags]
  }
}
{% endfor %}
{% endif %}
