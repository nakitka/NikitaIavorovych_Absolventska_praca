# Terraform variables for Gitea Infrastructure
# Generated by Gitea Infrastructure Deployment

variable "vsphere_server" {
  description = "vCenter server hostname or IP"
  type        = string
  default     = "{{ vsphere.vcenter_server }}"
}

variable "vsphere_user" {
  description = "vCenter username"
  type        = string
  default     = "{{ vsphere.username }}"
}

variable "vsphere_password" {
  description = "vCenter password"
  type        = string
  sensitive   = true
}

variable "datacenter" {
  description = "vSphere datacenter name"
  type        = string
  default     = "{{ vsphere.datacenter }}"
}

variable "cluster" {
  description = "vSphere cluster name"
  type        = string
  default     = "{{ vsphere.cluster }}"
}

variable "datastore" {
  description = "vSphere datastore name"
  type        = string
  default     = "{{ vsphere.datastore }}"
}

variable "network" {
  description = "vSphere network port group"
  type        = string
  default     = "{{ constants.VSPHERE_NETWORK_PORT_GROUP }}"
}

variable "vm_folder" {
  description = "VM folder path (relative to datacenter)"
  type        = string
  default     = "{{ vm_folder_relative }}"
}

variable "resource_pool" {
  description = "Resource pool name"
  type        = string
  default     = "Gitea-Production"
}
