# Terraform outputs for Gitea Infrastructure
# Generated by Gitea Infrastructure Deployment

# HAProxy VM IPs
{% for i in range(infrastructure.haproxy.count) %}
output "haproxy_{{ i + 1 }}_ip" {
  description = "IP address of haproxy-{{ i + 1 }}"
  value       = vsphere_virtual_machine.haproxy_{{ i + 1 }}.default_ip_address
}
{% endfor %}

# Master VM IPs
{% for i in range(infrastructure.control_plane.count) %}
output "master_{{ i + 1 }}_ip" {
  description = "IP address of master-{{ i + 1 }}"
  value       = vsphere_virtual_machine.master_{{ i + 1 }}.default_ip_address
}
{% endfor %}

# Worker VM IPs
{% for i in range(infrastructure.workers.count) %}
output "worker_{{ i + 1 }}_ip" {
  description = "IP address of worker-{{ i + 1 }}"
  value       = vsphere_virtual_machine.worker_{{ i + 1 }}.default_ip_address
}
{% endfor %}

# GlusterFS VM IPs
{% for i in range(infrastructure.glusterfs.count) %}
output "glusterfs_{{ i + 1 }}_ip" {
  description = "IP address of glusterfs-{{ i + 1 }}"
  value       = vsphere_virtual_machine.glusterfs_{{ i + 1 }}.default_ip_address
}
{% endfor %}

# Aggregated outputs
output "haproxy_ips" {
  description = "List of HAProxy VM IP addresses"
  value = [
    {% for i in range(infrastructure.haproxy.count) %}
    vsphere_virtual_machine.haproxy_{{ i + 1 }}.default_ip_address,
    {% endfor %}
  ]
}

output "master_ips" {
  description = "List of Kubernetes master IP addresses"
  value = [
    {% for i in range(infrastructure.control_plane.count) %}
    vsphere_virtual_machine.master_{{ i + 1 }}.default_ip_address,
    {% endfor %}
  ]
}

output "worker_ips" {
  description = "List of Kubernetes worker IP addresses"
  value = [
    {% for i in range(infrastructure.workers.count) %}
    vsphere_virtual_machine.worker_{{ i + 1 }}.default_ip_address,
    {% endfor %}
  ]
}

output "glusterfs_ips" {
  description = "List of GlusterFS VM IP addresses"
  value = [
    {% for i in range(infrastructure.glusterfs.count) %}
    vsphere_virtual_machine.glusterfs_{{ i + 1 }}.default_ip_address,
    {% endfor %}
  ]
}

output "virtual_ip" {
  description = "Virtual IP (VIP) for HAProxy"
  value       = "{{ network.vip_address }}"
}

output "kubernetes_api_endpoint" {
  description = "Kubernetes API endpoint"
  value       = "https://{{ network.vip_address }}:{{ K8S_API_PORT }}"
}

output "total_vms" {
  description = "Total number of VMs created"
  value       = {{ infrastructure.haproxy.count + infrastructure.control_plane.count + infrastructure.workers.count + infrastructure.glusterfs.count }}
}
