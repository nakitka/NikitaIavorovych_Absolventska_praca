#cloud-config
# Cloud-init configuration for Gitea Infrastructure VMs
# This file uses Terraform templatefile syntax for runtime substitution

hostname: ${hostname}

users:
  - name: root
    ssh_authorized_keys:
      - ${ssh_public_key}

ssh_pwauth: false

package_update: false
package_upgrade: false

# Network configuration
write_files:
  - path: /etc/network/interfaces
    content: |
      # This file describes the network interfaces available on your system
      # and how to activate them. For more information, see interfaces(5).

      source /etc/network/interfaces.d/*

      # The loopback network interface
      auto lo
      iface lo inet loopback

      # The primary network interface
      auto ens192
      iface ens192 inet static
        address ${ipv4_address}
        netmask ${ipv4_netmask}
        gateway ${ipv4_gateway}
        dns-nameservers ${dns_servers}
    permissions: '0644'

runcmd:
  # Set hostname
  - echo "${hostname}" > /etc/hostname
  - hostnamectl set-hostname ${hostname}
  # Kill DHCP client and release lease to prevent dual IPs
  - pkill dhclient || true
  - dhclient -r ens192 || true
  # Flush existing IPs from interface
  - ip addr flush dev ens192 || true
  # Bring interface down
  - ifdown ens192 || ip link set ens192 down || true
  # Apply new static configuration
  - ifup ens192 || ip link set ens192 up
  # Verify static IP is applied
  - ip addr show ens192

final_message: "Cloud-init completed for ${hostname}"
