---
# Backup Server Setup Playbook
# Generated by Gitea Infrastructure Deployment
#
# This playbook configures the backup VM to:
# - Mount backup storage disk
# - Install backup tools (kubectl, helm, rsync)
# - Copy kubeconfig for cluster access
# - Deploy backup scripts
# - Configure SSH access to worker nodes
# - Set up cron job for automated backups

- name: Configure Backup Server
  hosts: backup
  become: yes
  gather_facts: yes

  vars:
    backup_mount: "/backups"
    backup_disk: "/dev/sdb"
    kubeconfig_path: "/root/.kube/config"
    kubectl_version: "v1.35.0"
    helm_version: "v3.17.1"
    # backup_retention_days and backup_schedule come from inventory host vars
    master_ip: "{{ master_ips[0] }}"
    worker_ips:
{% for ip in worker_ips %}
      - "{{ ip }}"
{% endfor %}
    vip_address: "{{ vip_address }}"

  tasks:
    - name: Wait for system to be ready
      wait_for_connection:
        timeout: 300

    # ========================================
    # DISK SETUP
    # ========================================
    - name: Install required packages
      apt:
        name:
          - parted
          - xfsprogs
          - rsync
          - curl
          - ca-certificates
        state: present
        update_cache: yes

    - name: Check if backup disk exists
      stat:
        path: "{{ '{{' }} backup_disk {{ '}}' }}"
      register: disk_stat

    - name: Check if backup disk is already mounted
      shell: mount | grep -q "{{ '{{' }} backup_disk {{ '}}' }}"
      register: disk_mounted
      failed_when: false
      changed_when: false

    - name: Create partition on backup disk
      parted:
        device: "{{ '{{' }} backup_disk {{ '}}' }}"
        number: 1
        state: present
        part_type: primary
        fs_type: xfs
      when: disk_stat.stat.exists and disk_mounted.rc != 0

    - name: Format backup disk as XFS
      filesystem:
        fstype: xfs
        dev: "{{ '{{' }} backup_disk {{ '}}' }}1"
        force: no
      when: disk_stat.stat.exists and disk_mounted.rc != 0
      ignore_errors: yes

    - name: Create backup mount directory
      file:
        path: "{{ '{{' }} backup_mount {{ '}}' }}"
        state: directory
        mode: '0755'

    - name: Mount backup disk
      mount:
        path: "{{ '{{' }} backup_mount {{ '}}' }}"
        src: "{{ '{{' }} backup_disk {{ '}}' }}1"
        fstype: xfs
        opts: defaults
        state: mounted
      when: disk_stat.stat.exists

    # ========================================
    # SSH KEY SETUP (must be before kubeconfig copy)
    # ========================================
    - name: Create .ssh directory
      file:
        path: /root/.ssh
        state: directory
        mode: '0700'

    - name: Copy deployment SSH key
      copy:
        src: "{{ ssh_private_key }}"
        dest: /root/.ssh/id_rsa
        mode: '0600'

    - name: Copy deployment SSH public key
      copy:
        src: "{{ ssh_public_key }}"
        dest: /root/.ssh/id_rsa.pub
        mode: '0644'

    # ========================================
    # KUBECTL & HELM INSTALLATION
    # ========================================
    - name: Create bin directory
      file:
        path: /usr/local/bin
        state: directory
        mode: '0755'

    - name: Download kubectl
      get_url:
        url: "https://dl.k8s.io/release/{{ '{{' }} kubectl_version {{ '}}' }}/bin/linux/amd64/kubectl"
        dest: /usr/local/bin/kubectl
        mode: '0755'
      register: kubectl_download
      retries: 3
      delay: 10

    - name: Download helm
      unarchive:
        src: "https://get.helm.sh/helm-{{ '{{' }} helm_version {{ '}}' }}-linux-amd64.tar.gz"
        dest: /tmp
        remote_src: yes
      register: helm_download
      retries: 3
      delay: 10

    - name: Install helm
      copy:
        src: /tmp/linux-amd64/helm
        dest: /usr/local/bin/helm
        mode: '0755'
        remote_src: yes

    # ========================================
    # KUBECONFIG SETUP
    # ========================================
    - name: Create .kube directory
      file:
        path: /root/.kube
        state: directory
        mode: '0700'

    - name: Copy kubeconfig from master
      shell: |
        scp -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null \
          -i /root/.ssh/id_rsa \
          root@{{ '{{' }} master_ip {{ '}}' }}:/etc/rancher/k3s/k3s.yaml \
          {{ '{{' }} kubeconfig_path {{ '}}' }}
      args:
        creates: "{{ '{{' }} kubeconfig_path {{ '}}' }}"

    - name: Update kubeconfig server address
      replace:
        path: "{{ '{{' }} kubeconfig_path {{ '}}' }}"
        regexp: 'https://127.0.0.1:6443'
        replace: "https://{{ '{{' }} vip_address {{ '}}' }}:6443"
      when: kubeconfig_path is defined

    - name: Test kubectl access
      shell: kubectl get nodes
      environment:
        KUBECONFIG: "{{ '{{' }} kubeconfig_path {{ '}}' }}"
      register: kubectl_test
      retries: 5
      delay: 10
      until: kubectl_test.rc == 0

    # ========================================
    # BACKUP DIRECTORIES
    # ========================================
    - name: Create backup subdirectories
      file:
        path: "{{ '{{' }} backup_mount {{ '}}' }}/{{ '{{' }} item {{ '}}' }}"
        state: directory
        mode: '0755'
      loop:
        - postgresql
        - gitea
        - secrets
        - logs

    # ========================================
    # BACKUP SCRIPTS
    # ========================================
    - name: Deploy PostgreSQL backup script
      copy:
        dest: "{{ '{{' }} backup_mount {{ '}}' }}/backup-postgres.sh"
        mode: '0755'
        content: |
          #!/bin/bash
          # PostgreSQL Backup Script
          # Backs up Gitea database via kubectl exec

          set -e
          BACKUP_DIR="{{ '{{' }} backup_mount {{ '}}' }}/postgresql"
          TIMESTAMP=$(date +%Y%m%d_%H%M%S)
          RETENTION_DAYS={{ '{{' }} backup_retention_days {{ '}}' }}

          export KUBECONFIG="{{ '{{' }} kubeconfig_path {{ '}}' }}"

          echo "[$(date)] Starting PostgreSQL backup..."

          # Get primary pod name
          PRIMARY_POD=$(kubectl get pods -n gitea -l cnpg.io/cluster=gitea-db,role=primary -o jsonpath='{.items[0].metadata.name}' 2>/dev/null)

          if [ -z "$PRIMARY_POD" ]; then
            echo "[$(date)] ERROR: Cannot find PostgreSQL primary pod"
            exit 1
          fi

          echo "[$(date)] Found primary pod: $PRIMARY_POD"

          # Perform backup using pg_dump
          kubectl exec -n gitea "$PRIMARY_POD" -- pg_dump -U postgres -d gitea -F c > "$BACKUP_DIR/gitea_${TIMESTAMP}.dump"

          if [ $? -eq 0 ]; then
            echo "[$(date)] Backup created: gitea_${TIMESTAMP}.dump"
            # Create a symlink to latest backup
            ln -sf "$BACKUP_DIR/gitea_${TIMESTAMP}.dump" "$BACKUP_DIR/gitea_latest.dump"
          else
            echo "[$(date)] ERROR: Backup failed"
            exit 1
          fi

          # Cleanup old backups
          echo "[$(date)] Cleaning up backups older than $RETENTION_DAYS days..."
          find "$BACKUP_DIR" -name "gitea_*.dump" -type f -mtime +$RETENTION_DAYS -delete

          echo "[$(date)] PostgreSQL backup completed"

    - name: Deploy Gitea backup script
      copy:
        dest: "{{ '{{' }} backup_mount {{ '}}' }}/backup-gitea.sh"
        mode: '0755'
        content: |
          #!/bin/bash
          # Gitea Repository Backup Script
          # Backs up Gitea repositories via rsync from GlusterFS mount

          set -e
          BACKUP_DIR="{{ '{{' }} backup_mount {{ '}}' }}/gitea"
          TIMESTAMP=$(date +%Y%m%d_%H%M%S)
          RETENTION_DAYS={{ '{{' }} backup_retention_days {{ '}}' }}
          SSH_KEY="/root/.ssh/id_rsa"

          # Worker node with GlusterFS mount
          WORKER_IP="{{ worker_ips[0] }}"
          GLUSTER_MOUNT="/mnt/glusterfs"

          echo "[$(date)] Starting Gitea repository backup..."

          # Create timestamped backup directory
          BACKUP_PATH="$BACKUP_DIR/repos_${TIMESTAMP}"
          mkdir -p "$BACKUP_PATH"

          # Rsync from worker's GlusterFS mount
          rsync -avz --delete \
            -e "ssh -i $SSH_KEY -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null" \
            "root@${WORKER_IP}:${GLUSTER_MOUNT}/gitea/" \
            "$BACKUP_PATH/"

          if [ $? -eq 0 ]; then
            echo "[$(date)] Backup created: repos_${TIMESTAMP}"
            # Update latest symlink
            rm -f "$BACKUP_DIR/repos_latest"
            ln -sf "$BACKUP_PATH" "$BACKUP_DIR/repos_latest"
          else
            echo "[$(date)] ERROR: Rsync failed"
            exit 1
          fi

          # Cleanup old backups
          echo "[$(date)] Cleaning up backups older than $RETENTION_DAYS days..."
          find "$BACKUP_DIR" -maxdepth 1 -name "repos_*" -type d -mtime +$RETENTION_DAYS -exec rm -rf {} \;

          echo "[$(date)] Gitea backup completed"

    - name: Deploy secrets backup script
      copy:
        dest: "{{ '{{' }} backup_mount {{ '}}' }}/backup-secrets.sh"
        mode: '0755'
        content: |
          #!/bin/bash
          # Kubernetes Secrets Backup Script
          # Exports all secrets from key namespaces

          set -e
          BACKUP_DIR="{{ '{{' }} backup_mount {{ '}}' }}/secrets"
          TIMESTAMP=$(date +%Y%m%d_%H%M%S)
          RETENTION_DAYS={{ '{{' }} backup_retention_days {{ '}}' }}

          export KUBECONFIG="{{ '{{' }} kubeconfig_path {{ '}}' }}"

          echo "[$(date)] Starting secrets backup..."

          # Create timestamped backup directory
          BACKUP_PATH="$BACKUP_DIR/secrets_${TIMESTAMP}"
          mkdir -p "$BACKUP_PATH"

          # Namespaces to backup
          NAMESPACES="gitea monitoring cnpg-system portainer kube-system"

          for NS in $NAMESPACES; do
            echo "[$(date)] Backing up secrets from namespace: $NS"
            mkdir -p "$BACKUP_PATH/$NS"
            kubectl get secrets -n "$NS" -o yaml > "$BACKUP_PATH/$NS/secrets.yaml" 2>/dev/null || true
          done

          # Backup all ConfigMaps as well
          for NS in $NAMESPACES; do
            echo "[$(date)] Backing up configmaps from namespace: $NS"
            kubectl get configmaps -n "$NS" -o yaml > "$BACKUP_PATH/$NS/configmaps.yaml" 2>/dev/null || true
          done

          echo "[$(date)] Backup created: secrets_${TIMESTAMP}"
          # Update latest symlink
          rm -f "$BACKUP_DIR/secrets_latest"
          ln -sf "$BACKUP_PATH" "$BACKUP_DIR/secrets_latest"

          # Cleanup old backups
          echo "[$(date)] Cleaning up backups older than $RETENTION_DAYS days..."
          find "$BACKUP_DIR" -maxdepth 1 -name "secrets_*" -type d -mtime +$RETENTION_DAYS -exec rm -rf {} \;

          echo "[$(date)] Secrets backup completed"

    - name: Deploy master backup script
      copy:
        dest: "{{ '{{' }} backup_mount {{ '}}' }}/run-all-backups.sh"
        mode: '0755'
        content: |
          #!/bin/bash
          # Master Backup Script
          # Runs all backup scripts and logs output

          BACKUP_DIR="{{ '{{' }} backup_mount {{ '}}' }}"
          LOG_DIR="$BACKUP_DIR/logs"
          TIMESTAMP=$(date +%Y%m%d_%H%M%S)
          LOG_FILE="$LOG_DIR/backup_${TIMESTAMP}.log"

          mkdir -p "$LOG_DIR"

          {
            echo "=========================================="
            echo "BACKUP RUN: $(date)"
            echo "=========================================="

            echo ""
            echo "=== PostgreSQL Backup ==="
            "$BACKUP_DIR/backup-postgres.sh" || echo "PostgreSQL backup failed!"

            echo ""
            echo "=== Gitea Repositories Backup ==="
            "$BACKUP_DIR/backup-gitea.sh" || echo "Gitea backup failed!"

            echo ""
            echo "=== Kubernetes Secrets Backup ==="
            "$BACKUP_DIR/backup-secrets.sh" || echo "Secrets backup failed!"

            echo ""
            echo "=========================================="
            echo "BACKUP COMPLETED: $(date)"
            echo "=========================================="
          } 2>&1 | tee "$LOG_FILE"

          # Cleanup old logs
          find "$LOG_DIR" -name "backup_*.log" -type f -mtime +30 -delete

    # ========================================
    # CRON JOB SETUP
    # ========================================
    - name: Configure backup cron job
      cron:
        name: "Daily infrastructure backup"
        minute: "{{ '{{' }} backup_schedule.split()[0] {{ '}}' }}"
        hour: "{{ '{{' }} backup_schedule.split()[1] {{ '}}' }}"
        day: "{{ '{{' }} backup_schedule.split()[2] {{ '}}' }}"
        month: "{{ '{{' }} backup_schedule.split()[3] {{ '}}' }}"
        weekday: "{{ '{{' }} backup_schedule.split()[4] {{ '}}' }}"
        job: "{{ '{{' }} backup_mount {{ '}}' }}/run-all-backups.sh"
        user: root

    - name: Display backup configuration
      debug:
        msg: |
          Backup server configured successfully!

          Backup location: {{ '{{' }} backup_mount {{ '}}' }}
          Backup schedule: {{ '{{' }} backup_schedule {{ '}}' }}
          Retention: {{ '{{' }} backup_retention_days {{ '}}' }} days

          Manual backup command:
            {{ '{{' }} backup_mount {{ '}}' }}/run-all-backups.sh

          Check backups:
            ls -la {{ '{{' }} backup_mount {{ '}}' }}/postgresql/
            ls -la {{ '{{' }} backup_mount {{ '}}' }}/gitea/
            ls -la {{ '{{' }} backup_mount {{ '}}' }}/secrets/
