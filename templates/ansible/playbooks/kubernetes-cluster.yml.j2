---
# Kubernetes (K3s) Cluster Configuration Playbook
# Generated by Gitea Infrastructure Deployment

- name: Install K3s on first master (init cluster)
  hosts: masters[0]
  become: yes
  gather_facts: yes

  vars:
    k3s_version: "{{ K3S_VERSION }}"
    vip_address: "{{ vip_address }}"
    master_ip: "{{ master_ips[0] }}"

  tasks:
    - name: Wait for system to be ready
      wait_for_connection:
        timeout: 300

    - name: Install K3s server (cluster init)
      shell: |
        curl -sfL https://get.k3s.io | \
        INSTALL_K3S_VERSION="{{ '{{' }} k3s_version {{ '}}' }}" \
        INSTALL_K3S_EXEC="server \
          --cluster-init \
          --tls-san={{ '{{' }} vip_address {{ '}}' }} \
          --tls-san={{ '{{' }} master_ip {{ '}}' }} \
          --disable=traefik \
          --disable=servicelb \
          --write-kubeconfig-mode=644 \
          --etcd-arg=heartbeat-interval=1000 \
          --etcd-arg=election-timeout=10000" \
        sh -
      args:
        creates: /etc/rancher/k3s/k3s.yaml

    - name: Wait for K3s to be ready
      wait_for:
        port: 6443
        timeout: 120

    - name: Wait for node to be ready
      shell: kubectl get nodes --no-headers | grep -w Ready
      register: node_ready
      retries: 30
      delay: 10
      until: node_ready.rc == 0

    - name: Get K3s token
      slurp:
        src: /var/lib/rancher/k3s/server/node-token
      register: k3s_token_file

    - name: Set K3s token fact
      set_fact:
        k3s_token: "{{ '{{' }} k3s_token_file.content | b64decode | trim {{ '}}' }}"

    - name: Save token to local file
      copy:
        content: "{{ '{{' }} k3s_token {{ '}}' }}"
        dest: /tmp/k3s-token
      delegate_to: localhost
      become: no

- name: Install K3s on additional masters
  hosts: masters[1:]
  become: yes
  gather_facts: yes
  serial: 1

  vars:
    k3s_version: "{{ K3S_VERSION }}"
    vip_address: "{{ vip_address }}"
    first_master: "{{ master_ips[0] }}"

  tasks:
    - name: Read K3s token
      slurp:
        src: /tmp/k3s-token
      register: k3s_token_file
      delegate_to: localhost
      become: no

    - name: Set K3s token
      set_fact:
        k3s_token: "{{ '{{' }} k3s_token_file.content | b64decode | trim {{ '}}' }}"

    - name: Install K3s server (join cluster)
      shell: |
        curl -sfL https://get.k3s.io | \
        INSTALL_K3S_VERSION="{{ '{{' }} k3s_version {{ '}}' }}" \
        K3S_TOKEN="{{ '{{' }} k3s_token {{ '}}' }}" \
        INSTALL_K3S_EXEC="server \
          --server https://{{ '{{' }} first_master {{ '}}' }}:6443 \
          --tls-san={{ '{{' }} vip_address {{ '}}' }} \
          --disable=traefik \
          --disable=servicelb \
          --etcd-arg=heartbeat-interval=1000 \
          --etcd-arg=election-timeout=10000" \
        sh -
      args:
        creates: /etc/rancher/k3s/k3s.yaml

    - name: Wait for K3s to be ready
      wait_for:
        port: 6443
        timeout: 120

    - name: Wait for node to join
      shell: kubectl get nodes --no-headers | wc -l
      register: node_count
      retries: 30
      delay: 10
      until: node_count.stdout | int >= 1
      delegate_to: "{{ '{{' }} groups['masters'][0] {{ '}}' }}"

- name: Install K3s on workers
  hosts: workers
  become: yes
  gather_facts: yes

  vars:
    k3s_version: "{{ K3S_VERSION }}"
    vip_address: "{{ vip_address }}"

  tasks:
    - name: Read K3s token
      slurp:
        src: /tmp/k3s-token
      register: k3s_token_file
      delegate_to: localhost
      become: no

    - name: Set K3s token
      set_fact:
        k3s_token: "{{ '{{' }} k3s_token_file.content | b64decode | trim {{ '}}' }}"

    - name: Install K3s agent
      shell: |
        curl -sfL https://get.k3s.io | \
        INSTALL_K3S_VERSION="{{ '{{' }} k3s_version {{ '}}' }}" \
        K3S_URL="https://{{ '{{' }} vip_address {{ '}}' }}:6443" \
        K3S_TOKEN="{{ '{{' }} k3s_token {{ '}}' }}" \
        sh -
      args:
        creates: /var/lib/rancher/k3s/agent/kubelet.kubeconfig

    - name: Wait for agent to be ready
      pause:
        seconds: 30

- name: Install GlusterFS client and mount storage on Kubernetes nodes
  hosts: kubernetes
  become: yes
  gather_facts: yes

  vars:
    glusterfs_mount_point: /mnt/glusterfs
    glusterfs_volume: {{ GLUSTER_VOLUME_NAME }}
    glusterfs_server: {{ glusterfs_ips[0] }}

  tasks:
    - name: Install GlusterFS client
      apt:
        name: glusterfs-client
        state: present
        update_cache: yes

    - name: Load fuse module
      modprobe:
        name: fuse
        state: present

    - name: Ensure fuse loads on boot
      lineinfile:
        path: /etc/modules-load.d/fuse.conf
        line: fuse
        create: yes

    - name: Create GlusterFS mount point
      file:
        path: "{{ '{{' }} glusterfs_mount_point {{ '}}' }}"
        state: directory
        mode: '0755'

    - name: Mount GlusterFS volume
      mount:
        path: "{{ '{{' }} glusterfs_mount_point {{ '}}' }}"
        src: "{{ '{{' }} glusterfs_server {{ '}}' }}:/{{ '{{' }} glusterfs_volume {{ '}}' }}"
        fstype: glusterfs
        opts: defaults,_netdev,backup-volfile-servers={{ glusterfs_ips | join(':') }}
        state: mounted

    - name: Create storage subdirectories on GlusterFS
      file:
        path: "{{ '{{' }} glusterfs_mount_point {{ '}}' }}/{{ '{{' }} item {{ '}}' }}"
        state: directory
        mode: '0777'
      loop:
        - gitea
        - postgresql
        - redis
        - prometheus
        - grafana
        - portainer
      run_once: true

- name: Configure local-path provisioner to use GlusterFS
  hosts: masters[0]
  become: yes
  gather_facts: no

  tasks:
    - name: Wait for local-path-provisioner to be ready
      shell: kubectl get pods -n kube-system -l app=local-path-provisioner --no-headers | grep Running
      register: local_path_ready
      retries: 30
      delay: 10
      until: local_path_ready.rc == 0

    - name: Patch local-path-config to use GlusterFS mount
      shell: |
        kubectl patch configmap local-path-config -n kube-system --type=json -p='[
          {"op": "replace", "path": "/data/config.json", "value": "{\"nodePathMap\":[{\"node\":\"DEFAULT_PATH_FOR_NON_LISTED_NODES\",\"paths\":[\"/mnt/glusterfs\"]}]}"}
        ]'
      register: patch_result
      changed_when: patch_result.rc == 0

    - name: Restart local-path-provisioner to apply changes
      shell: kubectl rollout restart deployment local-path-provisioner -n kube-system
      when: patch_result.changed

    - name: Wait for local-path-provisioner restart
      shell: kubectl rollout status deployment local-path-provisioner -n kube-system --timeout=60s
      when: patch_result.changed

    - name: Set local-path as default StorageClass
      shell: |
        kubectl patch storageclass local-path -p '{"metadata": {"annotations":{"storageclass.kubernetes.io/is-default-class":"true"}}}'

- name: Verify cluster status
  hosts: masters[0]
  become: yes
  gather_facts: no

  tasks:
    - name: Get cluster nodes
      shell: kubectl get nodes -o wide
      register: cluster_nodes
      changed_when: false

    - name: Display cluster nodes
      debug:
        var: cluster_nodes.stdout_lines

    - name: Get system pods
      shell: kubectl get pods -n kube-system
      register: system_pods
      changed_when: false

    - name: Display system pods
      debug:
        var: system_pods.stdout_lines

    - name: Copy kubeconfig to standard location
      copy:
        src: /etc/rancher/k3s/k3s.yaml
        dest: /root/.kube/config
        remote_src: yes
        mode: '0600'

    - name: Update kubeconfig server URL to VIP
      replace:
        path: /root/.kube/config
        regexp: '127\.0\.0\.1'
        replace: "{{ vip_address }}"
