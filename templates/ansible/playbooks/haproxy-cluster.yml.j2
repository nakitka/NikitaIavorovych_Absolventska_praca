---
# HAProxy and Keepalived Cluster Configuration Playbook
# Generated by Gitea Infrastructure Deployment

- name: Configure HAProxy and Keepalived Cluster
  hosts: haproxy
  become: yes
  gather_facts: yes

  vars:
    vip_address: "{{ vip_address }}"
    master_nodes:
{% for ip in master_ips %}
      - "{{ ip }}"
{% endfor %}
    worker_nodes:
{% for ip in worker_ips %}
      - "{{ ip }}"
{% endfor %}
    haproxy_stats_port: {{ HAPROXY_STATS_PORT }}
    k8s_api_port: {{ K8S_API_PORT }}
    traefik_http_nodeport: {{ TRAEFIK_HTTP_NODEPORT }}
    keepalived_password: "{{ passwords.keepalived_password }}"

  tasks:
    - name: Wait for system to be ready
      wait_for_connection:
        timeout: 300

    - name: Ensure HAProxy is installed
      apt:
        name:
          - haproxy
          - keepalived
        state: present
        update_cache: yes

    - name: Enable non-local IP binding
      sysctl:
        name: net.ipv4.ip_nonlocal_bind
        value: '1'
        sysctl_set: yes
        state: present
        reload: yes

    - name: Configure HAProxy
      copy:
        dest: /etc/haproxy/haproxy.cfg
        mode: '0644'
        content: |
          global
              log /dev/log local0
              log /dev/log local1 notice
              chroot /var/lib/haproxy
              stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
              stats timeout 30s
              user haproxy
              group haproxy
              daemon
              maxconn 10000

          defaults
              log     global
              mode    tcp
              option  tcplog
              option  dontlognull
              timeout connect 5000ms
              timeout client  50000ms
              timeout server  50000ms
              retries 3

          # Kubernetes API frontend
          frontend k8s-api
              bind *:{{ '{{' }} k8s_api_port {{ '}}' }}
              mode tcp
              option tcplog
              default_backend k8s-masters

          # Kubernetes API backend
          backend k8s-masters
              mode tcp
              balance roundrobin
              option tcp-check
{% for ip in master_ips %}
              server master-{{ loop.index }} {{ ip }}:{{ '{{' }} k8s_api_port {{ '}}' }} check inter 2000 rise 2 fall 3
{% endfor %}

          # Gitea/Traefik HTTP frontend
          frontend gitea-web
              bind *:80
              mode http
              option httplog
              default_backend gitea-ingress

          # Gitea/Traefik backend
          backend gitea-ingress
              mode http
              balance roundrobin
              option httpchk GET /
              http-check expect rstatus (2|4)[0-9][0-9]
{% for ip in worker_ips %}
              server worker-{{ loop.index }} {{ ip }}:{{ '{{' }} traefik_http_nodeport {{ '}}' }} check inter 2000 rise 2 fall 3
{% endfor %}

          # HAProxy stats page
          listen stats
              bind *:{{ '{{' }} haproxy_stats_port {{ '}}' }}
              mode http
              stats enable
              stats uri /stats
              stats refresh 10s
              stats admin if LOCALHOST
      notify: Restart HAProxy

    - name: Validate HAProxy configuration
      command: haproxy -c -f /etc/haproxy/haproxy.cfg
      changed_when: false

    - name: Get primary network interface
      shell: ip route | grep default | awk '{print $5}' | head -1
      register: primary_interface
      changed_when: false

    - name: Configure Keepalived
      copy:
        dest: /etc/keepalived/keepalived.conf
        mode: '0644'
        content: |
          global_defs {
              router_id LVS_HAPROXY_{{ '{{' }} inventory_hostname | upper | replace('-', '_') {{ '}}' }}
              enable_script_security
          }

          vrrp_script chk_haproxy {
              script "killall -0 haproxy"
              interval 2
              weight -20
              fall 3
              rise 2
          }

          vrrp_instance VI_1 {
              state {{ '{{' }} haproxy_role {{ '}}' }}
              interface {{ '{{' }} primary_interface.stdout {{ '}}' }}
              virtual_router_id 51
              priority {{ '{{' }} haproxy_priority {{ '}}' }}
              advert_int 1

              authentication {
                  auth_type PASS
                  auth_pass {{ '{{' }} keepalived_password {{ '}}' }}
              }

              virtual_ipaddress {
                  {{ '{{' }} vip_address {{ '}}' }}/24
              }

              track_script {
                  chk_haproxy
              }
          }
      notify: Restart Keepalived

    - name: Start and enable HAProxy
      systemd:
        name: haproxy
        state: started
        enabled: yes

    - name: Start and enable Keepalived
      systemd:
        name: keepalived
        state: started
        enabled: yes

    - name: Wait for services to stabilize
      pause:
        seconds: 5

    - name: Check VIP assignment
      shell: "ip addr show | grep {{ '{{' }} vip_address {{ '}}' }}"
      register: vip_check
      changed_when: false
      failed_when: false

    - name: Display VIP status
      debug:
        msg: "VIP {{ '{{' }} vip_address {{ '}}' }} is assigned to this node"
      when: vip_check.rc == 0

  handlers:
    - name: Restart HAProxy
      systemd:
        name: haproxy
        state: restarted

    - name: Restart Keepalived
      systemd:
        name: keepalived
        state: restarted
