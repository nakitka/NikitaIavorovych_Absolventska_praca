---
# GlusterFS Cluster Configuration Playbook
# Generated by Gitea Infrastructure Deployment

- name: Configure GlusterFS Cluster
  hosts: glusterfs
  become: yes
  gather_facts: yes

  vars:
    gluster_volume_name: "{{ GLUSTER_VOLUME_NAME }}"
    gluster_brick_path: "{{ GLUSTER_BRICK_PATH }}"
    data_disk: "/dev/sdb"

  tasks:
    - name: Wait for system to be ready
      wait_for_connection:
        timeout: 300

    - name: Install required packages
      apt:
        name:
          - parted
          - xfsprogs
          - glusterfs-server
        state: present
        update_cache: yes

    - name: Check if data disk exists
      stat:
        path: "{{ '{{' }} data_disk {{ '}}' }}"
      register: disk_stat

    - name: Check if data disk is already mounted
      shell: mount | grep -q "{{ '{{' }} data_disk {{ '}}' }}"
      register: disk_mounted
      failed_when: false
      changed_when: false

    - name: Create partition on data disk
      parted:
        device: "{{ '{{' }} data_disk {{ '}}' }}"
        number: 1
        state: present
        part_type: primary
        fs_type: xfs
      when: disk_stat.stat.exists and disk_mounted.rc != 0

    - name: Format data disk as XFS
      filesystem:
        fstype: xfs
        dev: "{{ '{{' }} data_disk {{ '}}' }}"
        opts: "-i size=512"
        force: no
      when: disk_stat.stat.exists and disk_mounted.rc != 0

    - name: Create brick directory
      file:
        path: "{{ '{{' }} gluster_brick_path {{ '}}' }}"
        state: directory
        mode: '0755'

    - name: Check if data disk is already mounted anywhere
      shell: mount | grep -q "{{ '{{' }} data_disk {{ '}}' }}"
      register: disk_mounted
      failed_when: false
      changed_when: false

    - name: Check if brick path is already a mount point
      shell: mountpoint -q "{{ '{{' }} gluster_brick_path {{ '}}' }}"
      register: brick_is_mountpoint
      failed_when: false
      changed_when: false

    - name: Mount data disk (only if not already mounted)
      mount:
        path: "{{ '{{' }} gluster_brick_path {{ '}}' }}"
        src: "{{ '{{' }} data_disk {{ '}}' }}"
        fstype: xfs
        opts: defaults
        state: mounted
      when: disk_stat.stat.exists and disk_mounted.rc != 0 and brick_is_mountpoint.rc != 0

    - name: Create brick directory with GlusterFS structure
      file:
        path: "{{ '{{' }} gluster_brick_path {{ '}}' }}/brick/.glusterfs/indices"
        state: directory
        mode: '0755'
        owner: root
        group: root

    - name: Start and enable GlusterFS service
      systemd:
        name: glusterd
        state: started
        enabled: yes

    - name: Wait for GlusterFS to start
      wait_for:
        port: 24007
        timeout: 60

- name: Create GlusterFS Cluster (run on primary node only)
  hosts: glusterfs
  become: yes
  run_once: yes

  vars:
    gluster_volume_name: "{{ GLUSTER_VOLUME_NAME }}"
    gluster_brick_path: "{{ GLUSTER_BRICK_PATH }}"
    gluster_nodes:
{% for ip in glusterfs_ips %}
      - "{{ ip }}"
{% endfor %}

  tasks:
    - name: Probe peer nodes
      command: "gluster peer probe {{ '{{' }} item {{ '}}' }}"
      loop: "{{ '{{' }} gluster_nodes[1:] {{ '}}' }}"
      register: peer_probe
      changed_when: "'already in peer list' not in peer_probe.stdout"
      failed_when: false

    - name: Wait for peers to connect
      pause:
        seconds: 10

    - name: Check peer status
      command: gluster peer status
      register: peer_status
      changed_when: false

    - name: Display peer status
      debug:
        var: peer_status.stdout_lines

    - name: Check if volume exists
      command: "gluster volume info {{ '{{' }} gluster_volume_name {{ '}}' }}"
      register: volume_info
      failed_when: false
      changed_when: false

    - name: Create GlusterFS volume
      command: >
        gluster volume create {{ '{{' }} gluster_volume_name {{ '}}' }} replica 3
{% for ip in glusterfs_ips %}
        {{ ip }}:{{ '{{' }} gluster_brick_path {{ '}}' }}/brick
{% endfor %}
        force
      when: volume_info.rc != 0

    - name: Start GlusterFS volume
      command: "gluster volume start {{ '{{' }} gluster_volume_name {{ '}}' }}"
      register: volume_start
      failed_when: false
      changed_when: "'already started' not in volume_start.stderr"

    - name: Set volume options for performance
      command: "gluster volume set {{ '{{' }} gluster_volume_name {{ '}}' }} {{ '{{' }} item.key {{ '}}' }} {{ '{{' }} item.value {{ '}}' }}"
      loop:
        - { key: "performance.cache-size", value: "256MB" }
        - { key: "network.ping-timeout", value: "10" }
        - { key: "cluster.self-heal-daemon", value: "on" }
        - { key: "cluster.heal-timeout", value: "600" }
      failed_when: false

    - name: Verify volume status
      command: "gluster volume status {{ '{{' }} gluster_volume_name {{ '}}' }}"
      register: volume_status
      changed_when: false

    - name: Display volume status
      debug:
        var: volume_status.stdout_lines
