# Ansible inventory for Gitea Infrastructure
# Generated by Gitea Infrastructure Deployment

all:
  vars:
    # SSH configuration
    ansible_user: root
    ansible_ssh_private_key_file: "{{ ssh_private_key }}"
    ansible_ssh_common_args: "-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"

    # Network configuration
    vip_address: "{{ vip_address }}"
    gateway: "{{ network.gateway }}"
    subnet_mask: "{{ network.subnet_mask }}"
    dns_servers:
{% for dns in network.dns_servers %}
      - "{{ dns }}"
{% endfor %}

    # GlusterFS configuration
    gluster_volume_name: "{{ GLUSTER_VOLUME_NAME }}"
    gluster_brick_path: "{{ GLUSTER_BRICK_PATH }}"
    gluster_nodes:
{% for ip in glusterfs_ips %}
      - "{{ ip }}"
{% endfor %}

    # Kubernetes configuration
    k3s_version: "{{ K3S_VERSION }}"
    k8s_api_port: {{ K8S_API_PORT }}
    master_nodes:
{% for ip in master_ips %}
      - "{{ ip }}"
{% endfor %}
    worker_nodes:
{% for ip in worker_ips %}
      - "{{ ip }}"
{% endfor %}

    # HAProxy configuration
    haproxy_stats_port: {{ HAPROXY_STATS_PORT }}
    traefik_http_nodeport: {{ TRAEFIK_HTTP_NODEPORT }}
    keepalived_password: "{{ passwords.keepalived_password }}"

    # Passwords
    root_password: "{{ passwords.root_password }}"

  children:
    haproxy:
      hosts:
{% for i in range(haproxy_ips | length) %}
        haproxy-{{ i + 1 }}:
          ansible_host: {{ haproxy_ips[i] }}
          haproxy_role: {{ "MASTER" if i == 0 else "BACKUP" }}
          haproxy_priority: {{ 100 if i == 0 else 90 - i * 10 }}
{% endfor %}

    masters:
      hosts:
{% for i in range(master_ips | length) %}
        master-{{ i + 1 }}:
          ansible_host: {{ master_ips[i] }}
          k3s_role: {{ "init" if i == 0 else "server" }}
{% endfor %}

    workers:
      hosts:
{% for i in range(worker_ips | length) %}
        worker-{{ i + 1 }}:
          ansible_host: {{ worker_ips[i] }}
          k3s_role: agent
{% endfor %}

    glusterfs:
      hosts:
{% for i in range(glusterfs_ips | length) %}
        glusterfs-{{ i + 1 }}:
          ansible_host: {{ glusterfs_ips[i] }}
          gluster_primary: {{ "true" if i == 0 else "false" }}
{% endfor %}

{% if backup_ips is defined and backup_ips | length > 0 %}
    backup:
      hosts:
{% for i in range(backup_ips | length) %}
        backup-{{ i + 1 }}:
          ansible_host: {{ backup_ips[i] }}
          backup_retention_days: {{ infrastructure.backup.retention_days | default(7) }}
          backup_schedule: "{{ infrastructure.backup.schedule | default('0 2 * * *') }}"
{% endfor %}
{% endif %}

    kubernetes:
      children:
        masters:
        workers:
