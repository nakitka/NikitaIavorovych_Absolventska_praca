# Ansible configuration for Gitea Infrastructure
# Generated by Gitea Infrastructure Deployment

[defaults]
inventory = inventory.yml
remote_user = root
host_key_checking = False
timeout = 120
# Reduced forks to avoid overwhelming jump host with simultaneous connections
forks = 3
gathering = smart
fact_caching = memory
retry_files_enabled = False
interpreter_python = auto_silent

[privilege_escalation]
become = True
become_method = sudo
become_user = root
become_ask_pass = False

[ssh_connection]
pipelining = True
# Use ControlMaster to reuse connections and reduce jump host load
control_path_dir = /tmp/ansible-ssh-%%h-%%p-%%r
ssh_args = -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=60 -o ServerAliveInterval=30 -o ServerAliveCountMax=3 -o ControlMaster=auto -o ControlPersist=60s
