# Packer configuration for Kubernetes VM template
# Generated by Gitea Infrastructure Deployment

packer {
  required_plugins {
    vsphere = {
      source  = "github.com/hashicorp/vsphere"
      version = "~> 1"
    }
  }
}

variable "vsphere_server" {
  type    = string
  default = "{{ vsphere.vcenter_server }}"
}

variable "vsphere_user" {
  type    = string
  default = "{{ vsphere.username }}"
}

variable "vsphere_password" {
  type      = string
  sensitive = true
}

variable "vsphere_datacenter" {
  type    = string
  default = "{{ vsphere.datacenter }}"
}

variable "vsphere_cluster" {
  type    = string
  default = "{{ vsphere.cluster }}"
}

variable "vsphere_datastore" {
  type    = string
  default = "{{ vsphere.datastore }}"
}

variable "vsphere_network" {
  type    = string
  default = "{{ constants.VSPHERE_NETWORK_PORT_GROUP }}"
}

variable "vsphere_folder" {
  type    = string
  default = "{{ template_folder_relative }}"
}

variable "iso_path" {
  type    = string
  default = "{{ constants.VSPHERE_ISO_PATH }}"
}

variable "preseed_url" {
  type        = string
  description = "URL to preseed.cfg file on remote HTTP server"
  default     = "{{ preseed_url }}"
}

source "vsphere-iso" "kubernetes" {
  vcenter_server      = var.vsphere_server
  username            = var.vsphere_user
  password            = var.vsphere_password
  insecure_connection = true

  datacenter = var.vsphere_datacenter
  cluster    = var.vsphere_cluster
  datastore  = var.vsphere_datastore
  folder     = var.vsphere_folder

  vm_name              = "{{ constants.TEMPLATE_NAMES.kubernetes }}"
  guest_os_type        = "{{ constants.OS_GUEST_ID }}"
  CPUs                 = {{ infrastructure.control_plane.cpu }}
  RAM                  = {{ infrastructure.control_plane.ram_gb * 1024 }}
  RAM_reserve_all      = false
  disk_controller_type = ["pvscsi"]

  storage {
    disk_size             = {{ infrastructure.control_plane.disk_gb * 1024 }}
    disk_thin_provisioned = true
  }

  network_adapters {
    network      = var.vsphere_network
    network_card = "vmxnet3"
  }

  iso_paths = [var.iso_path]

  boot_command = [
    "<esc><wait>",
    "auto url=${var.preseed_url}<wait> ",
    "debian-installer=en_US.UTF-8<wait> ",
    "locale=en_US.UTF-8<wait> ",
    "kbd-chooser/method=us<wait> ",
    "keyboard-configuration/xkb-keymap=us<wait> ",
    "netcfg/get_hostname=kubernetes-template<wait> ",
    "netcfg/get_domain=<wait> ",
    "fb=false<wait> ",
    "debconf/frontend=noninteractive<wait> ",
    "console-setup/ask_detect=false<wait> ",
    "console-keymaps-at/keymap=us<wait> ",
    "grub-installer/bootdev=/dev/sda<wait> ",
    "<enter>"
  ]

  boot_wait              = "15s"
  boot_keygroup_interval = "500ms"

  ssh_username = "root"
  ssh_password = "{{ passwords.root_password }}"
  ssh_timeout  = "30m"

  shutdown_command = "shutdown -P now"
  shutdown_timeout = "10m"

  remove_cdrom        = true
  convert_to_template = true

  configuration_parameters = {
    "disk.EnableUUID" = "TRUE"
  }
}

build {
  sources = ["source.vsphere-iso.kubernetes"]

  provisioner "shell" {
    scripts = [
      "scripts/base-provision.sh",
      "scripts/kubernetes-provision.sh"
    ]
  }
}
