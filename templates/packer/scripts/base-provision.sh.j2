#!/bin/bash
# Base provisioning script for all VM templates
# Generated by Gitea Infrastructure Deployment

set -e

echo "=== Starting base provisioning ==="

# Update system
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get upgrade -y

# Install base packages
apt-get install -y \
    curl \
    wget \
    vim \
    net-tools \
    gnupg \
    lsb-release \
    ca-certificates \
    apt-transport-https \
    software-properties-common \
    python3 \
    python3-pip \
    sudo \
    open-vm-tools \
    cloud-init \
    jq \
    htop \
    iotop \
    dnsutils \
    iputils-ping \
    tcpdump \
    nfs-common

# Configure SSH
sed -i 's/^#PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config
sed -i 's/^PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config
sed -i 's/^#PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config
sed -i 's/^PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config

# Create SSH directory for root
mkdir -p /root/.ssh
chmod 700 /root/.ssh

# Enable services
systemctl enable ssh
systemctl enable open-vm-tools

# Configure cloud-init for VMware guestinfo datasource
mkdir -p /etc/cloud/cloud.cfg.d
cat > /etc/cloud/cloud.cfg.d/99-vmware-guestinfo.cfg << 'EOF'
# Disable cloud-init networking (we configure it via userdata)
network:
  config: disabled

# Configure datasource for VMware guestinfo
datasource_list: [ VMware, OVF, None ]
datasource:
  VMware:
    allow_raw_data: true
    vmware_cust_file_max_wait: 10
EOF

# Install VMware guestinfo datasource for cloud-init
# This allows cloud-init to read userdata from guestinfo.userdata
pip3 install cloud-init-vmware-guestinfo || true

# Configure timezone
timedatectl set-timezone UTC

# Disable swap
swapoff -a
sed -i '/swap/d' /etc/fstab

# Configure kernel parameters for containers
cat >> /etc/sysctl.d/99-kubernetes.conf << 'EOF'
net.bridge.bridge-nf-call-iptables = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward = 1
net.ipv4.conf.all.forwarding = 1
fs.inotify.max_user_instances = 8192
fs.inotify.max_user_watches = 524288
EOF

# Load required kernel modules
cat > /etc/modules-load.d/containerd.conf << 'EOF'
overlay
br_netfilter
EOF

modprobe overlay || true
modprobe br_netfilter || true

# Apply sysctl settings
sysctl --system || true

# Configure network interface to manual (no DHCP) - cloud-init will set static IP
# This prevents dual IP issue when VM boots with DHCP then cloud-init adds static
cat > /etc/network/interfaces << 'EOF'
# This file describes the network interfaces available on your system
# and how to activate them. For more information, see interfaces(5).

source /etc/network/interfaces.d/*

# The loopback network interface
auto lo
iface lo inet loopback

# The primary network interface - configured by cloud-init
# Set to manual to prevent DHCP on boot - cloud-init will configure static IP
auto ens192
iface ens192 inet manual
EOF

# Disable dhclient service to prevent DHCP on boot
systemctl disable dhclient.service || true
systemctl mask dhclient.service || true

# Remove any DHCP leases
rm -rf /var/lib/dhcp/* || true

# Clean up cloud-init for template
cloud-init clean --logs || true

# Remove machine-id for cloning
truncate -s 0 /etc/machine-id || true
rm -f /var/lib/dbus/machine-id || true

# Clean up apt cache
apt-get clean
rm -rf /var/lib/apt/lists/*

# Remove temporary files
rm -rf /tmp/*
rm -rf /var/tmp/*

# Clear logs
journalctl --vacuum-time=1s || true
find /var/log -type f -exec truncate -s 0 {} \;

echo "=== Base provisioning complete ==="
