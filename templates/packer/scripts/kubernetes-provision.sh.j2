#!/bin/bash
# Kubernetes provisioning script
# Generated by Gitea Infrastructure Deployment

set -e

echo "=== Starting Kubernetes provisioning ==="

export DEBIAN_FRONTEND=noninteractive

# Install container runtime dependencies
apt-get update
apt-get install -y \
    iptables \
    conntrack \
    socat \
    util-linux \
    ethtool \
    ebtables \
    ipvsadm

# Install GlusterFS client for mounting persistent volumes
apt-get install -y glusterfs-client

# Ensure kernel modules are loaded
modprobe overlay || true
modprobe br_netfilter || true
modprobe ip_vs || true
modprobe ip_vs_rr || true
modprobe ip_vs_wrr || true
modprobe ip_vs_sh || true
modprobe nf_conntrack || true

# Persist kernel modules
cat > /etc/modules-load.d/kubernetes.conf << 'EOF'
overlay
br_netfilter
ip_vs
ip_vs_rr
ip_vs_wrr
ip_vs_sh
nf_conntrack
EOF

# Configure kernel parameters
cat > /etc/sysctl.d/99-kubernetes.conf << 'EOF'
net.bridge.bridge-nf-call-iptables = 1
net.bridge.bridge-nf-call-ip6tables = 1
net.ipv4.ip_forward = 1
net.ipv4.conf.all.forwarding = 1
net.ipv6.conf.all.forwarding = 1
net.ipv4.tcp_keepalive_time = 600
net.ipv4.tcp_keepalive_intvl = 30
net.ipv4.tcp_keepalive_probes = 10
vm.swappiness = 0
fs.file-max = 2097152
fs.inotify.max_user_instances = 8192
fs.inotify.max_user_watches = 524288
EOF

sysctl --system || true

# Disable swap permanently
swapoff -a
sed -i '/swap/d' /etc/fstab

# Pre-download K3s binary (will use specific version during Ansible)
# This speeds up the installation during cluster setup
mkdir -p /var/lib/rancher/k3s/agent/images/

# Create K3s directories
mkdir -p /etc/rancher/k3s
mkdir -p /var/lib/rancher/k3s/server/manifests

# Install bash completion
apt-get install -y bash-completion

# Prepare kubectl bash completion (will work after K3s install)
mkdir -p /etc/bash_completion.d

echo "=== Kubernetes provisioning complete ==="
