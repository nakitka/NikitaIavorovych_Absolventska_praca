#!/bin/bash
# GlusterFS provisioning script
# Generated by Gitea Infrastructure Deployment

set -e

echo "=== Starting GlusterFS provisioning ==="

export DEBIAN_FRONTEND=noninteractive

# Install GlusterFS server and disk tools
apt-get update
apt-get install -y \
    glusterfs-server \
    xfsprogs \
    parted \
    attr

# Enable GlusterFS service
systemctl enable glusterd

# Load required kernel modules for thin provisioning
modprobe dm_thin_pool || true
modprobe dm_snapshot || true

# Persist kernel modules
cat > /etc/modules-load.d/glusterfs.conf << 'EOF'
dm_thin_pool
dm_snapshot
fuse
EOF

# Configure GlusterFS directories
mkdir -p {{ constants.GLUSTER_BRICK_PATH }}

# Configure kernel parameters for GlusterFS performance
cat > /etc/sysctl.d/99-glusterfs.conf << 'EOF'
# GlusterFS performance tuning
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
net.ipv4.tcp_rmem = 4096 87380 16777216
net.ipv4.tcp_wmem = 4096 65536 16777216
net.core.netdev_max_backlog = 30000
net.ipv4.tcp_no_metrics_save = 1
net.ipv4.tcp_moderate_rcvbuf = 1
net.ipv4.tcp_timestamps = 0
net.ipv4.tcp_sack = 1
vm.dirty_ratio = 40
vm.dirty_background_ratio = 10
vm.swappiness = 10
EOF

sysctl --system || true

# Create script to format data disk (will be run by Ansible)
cat > /usr/local/bin/format-glusterfs-disk.sh << 'EOF'
#!/bin/bash
# Format and mount GlusterFS data disk

DATA_DISK="${1:-/dev/sdb}"
MOUNT_POINT="{{ constants.GLUSTER_BRICK_PATH }}"

# Check if disk exists
if [ ! -b "$DATA_DISK" ]; then
    echo "Disk $DATA_DISK not found"
    exit 1
fi

# Check if already formatted
if blkid "$DATA_DISK" | grep -q xfs; then
    echo "Disk already formatted"
else
    echo "Formatting $DATA_DISK as XFS..."
    mkfs.xfs -i size=512 "$DATA_DISK"
fi

# Create mount point
mkdir -p "$MOUNT_POINT"

# Add to fstab if not present
if ! grep -q "$MOUNT_POINT" /etc/fstab; then
    echo "$DATA_DISK $MOUNT_POINT xfs defaults 0 0" >> /etc/fstab
fi

# Mount
mount -a

echo "GlusterFS data disk ready at $MOUNT_POINT"
EOF

chmod +x /usr/local/bin/format-glusterfs-disk.sh

echo "=== GlusterFS provisioning complete ==="
