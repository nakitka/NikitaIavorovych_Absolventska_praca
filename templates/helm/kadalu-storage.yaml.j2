# Kadalu External GlusterFS Storage Configuration
# Generated by Gitea Infrastructure Deployment

---
apiVersion: kadalu-operator.storage/v1alpha1
kind: KadaluStorage
metadata:
  name: external-gluster
  namespace: kadalu
spec:
  type: External
  details:
    gluster_hosts:
{% for ip in glusterfs_ips %}
      - {{ ip }}
{% endfor %}
    gluster_volname: {{ GLUSTER_VOLUME_NAME }}
    gluster_options: ""

---
# Storage class for applications
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: {{ STORAGE_CLASS_NAME }}
  annotations:
    storageclass.kubernetes.io/is-default-class: "true"
provisioner: kadalu
parameters:
  storage_name: external-gluster
  gluster_volname: {{ GLUSTER_VOLUME_NAME }}
  gluster_hosts: "{{ glusterfs_ips | join(',') }}"
reclaimPolicy: Delete
volumeBindingMode: Immediate
allowVolumeExpansion: true
