# Prometheus Stack Helm values
# Generated by Gitea Infrastructure Deployment

# Prometheus Operator
prometheusOperator:
  enabled: true
  resources:
    requests:
      cpu: "100m"
      memory: "256Mi"
    limits:
      cpu: "500m"
      memory: "512Mi"
  # Schedule on worker nodes
  affinity:
    nodeAffinity:
      requiredDuringSchedulingIgnoredDuringExecution:
        nodeSelectorTerms:
          - matchExpressions:
              - key: node-role.kubernetes.io/control-plane
                operator: DoesNotExist

# Prometheus
prometheus:
  enabled: true
  prometheusSpec:
    replicas: {{ applications.prometheus.replicas }}
    retention: {{ applications.prometheus.retention_days }}d
    resources:
      requests:
        cpu: "250m"
        memory: "512Mi"
      limits:
        cpu: "1"
        memory: "2Gi"
    storageSpec:
      volumeClaimTemplate:
        spec:
          storageClassName: {{ STORAGE_CLASS_NAME }}
          accessModes: ["ReadWriteOnce"]
          resources:
            requests:
              storage: {{ applications.prometheus.storage_per_replica_gb }}Gi
    serviceMonitorSelectorNilUsesHelmValues: false
    podMonitorSelectorNilUsesHelmValues: false
    # Schedule on worker nodes
    affinity:
      nodeAffinity:
        requiredDuringSchedulingIgnoredDuringExecution:
          nodeSelectorTerms:
            - matchExpressions:
                - key: node-role.kubernetes.io/control-plane
                  operator: DoesNotExist

# Grafana
grafana:
  enabled: true
  replicas: {{ applications.grafana.replicas }}
  adminPassword: "{{ passwords.grafana_admin_password }}"
  persistence:
    enabled: true
    storageClassName: {{ STORAGE_CLASS_NAME }}
    size: {{ applications.grafana.storage_per_replica_gb }}Gi
  # Disable init-chown-data to avoid permission issues with GlusterFS
  initChownData:
    enabled: false
  securityContext:
    runAsUser: 472
    runAsGroup: 472
    fsGroup: 472
  service:
    type: ClusterIP
  ingress:
    enabled: true
    ingressClassName: traefik
    hosts:
      - {{ "grafana." + network.gitea_hostname.split('.', 1)[1] if network.gitea_hostname and '.' in network.gitea_hostname else "grafana.local" }}
    path: /
    pathType: Prefix
  resources:
    requests:
      cpu: "100m"
      memory: "256Mi"
    limits:
      cpu: "500m"
      memory: "512Mi"
  sidecar:
    dashboards:
      enabled: true
    datasources:
      enabled: true
  # Schedule on worker nodes
  affinity:
    nodeAffinity:
      requiredDuringSchedulingIgnoredDuringExecution:
        nodeSelectorTerms:
          - matchExpressions:
              - key: node-role.kubernetes.io/control-plane
                operator: DoesNotExist

# Alertmanager
alertmanager:
  enabled: true
  alertmanagerSpec:
    replicas: 1
    resources:
      requests:
        cpu: "50m"
        memory: "128Mi"
      limits:
        cpu: "200m"
        memory: "256Mi"
    # Schedule on worker nodes
    affinity:
      nodeAffinity:
        requiredDuringSchedulingIgnoredDuringExecution:
          nodeSelectorTerms:
            - matchExpressions:
                - key: node-role.kubernetes.io/control-plane
                  operator: DoesNotExist

# Node Exporter
nodeExporter:
  enabled: true

# Kube State Metrics
kubeStateMetrics:
  enabled: true

kube-state-metrics:
  # Increased probe timeouts
  livenessProbe:
    initialDelaySeconds: 30
    periodSeconds: 20
    timeoutSeconds: 15
    failureThreshold: 5
  readinessProbe:
    initialDelaySeconds: 30
    periodSeconds: 20
    timeoutSeconds: 15
    failureThreshold: 5
  # Schedule on worker nodes
  affinity:
    nodeAffinity:
      requiredDuringSchedulingIgnoredDuringExecution:
        nodeSelectorTerms:
          - matchExpressions:
              - key: node-role.kubernetes.io/control-plane
                operator: DoesNotExist

# Kubelet
kubelet:
  enabled: true

# Kube API Server
kubeApiServer:
  enabled: true

# Kube Controller Manager
kubeControllerManager:
  enabled: true
  endpoints:
{% for ip in master_ips %}
    - {{ ip }}
{% endfor %}

# Kube Scheduler
kubeScheduler:
  enabled: true
  endpoints:
{% for ip in master_ips %}
    - {{ ip }}
{% endfor %}

# Kube Proxy
kubeProxy:
  enabled: true

# etcd
kubeEtcd:
  enabled: true
  endpoints:
{% for ip in master_ips %}
    - {{ ip }}
{% endfor %}

# CoreDNS
coreDns:
  enabled: true

# Default rules
defaultRules:
  create: true
  rules:
    alertmanager: true
    etcd: true
    configReloaders: true
    general: true
    k8s: true
    kubeApiserverAvailability: true
    kubeApiserverBurnrate: true
    kubeApiserverHistogram: true
    kubeApiserverSlos: true
    kubeControllerManager: true
    kubelet: true
    kubeProxy: true
    kubePrometheusGeneral: true
    kubePrometheusNodeRecording: true
    kubernetesApps: true
    kubernetesResources: true
    kubernetesStorage: true
    kubernetesSystem: true
    kubeSchedulerAlerting: true
    kubeSchedulerRecording: true
    kubeStateMetrics: true
    network: true
    node: true
    nodeExporterAlerting: true
    nodeExporterRecording: true
    prometheus: true
    prometheusOperator: true
