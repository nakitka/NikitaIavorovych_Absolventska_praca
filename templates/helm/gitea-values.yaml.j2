# Gitea Helm values
# Generated by Gitea Infrastructure Deployment

# Image configuration
image:
  registry: docker.io
  repository: gitea/gitea
  tag: "1.25"
  pullPolicy: IfNotPresent

# Replica count
replicaCount: {{ applications.gitea.replicas }}

# Persistence - use gitea-glusterfs storage class with pre-created PV
persistence:
  enabled: true
  storageClass: gitea-glusterfs
  size: {{ applications.gitea.repository_storage_gb }}Gi
  accessModes:
    - ReadWriteMany

# Service configuration
service:
  http:
    type: ClusterIP
    port: 3000
  ssh:
    type: NodePort
    port: 22
    nodePort: {{ GITEA_SSH_NODEPORT }}

# Ingress configuration
ingress:
  enabled: true
  className: traefik
  annotations: {}
  hosts:
    - host: {{ network.gitea_hostname or vip_address }}
      paths:
        - path: /
          pathType: Prefix
  tls: []

# Gitea configuration
gitea:
  admin:
    username: gitea_admin
    password: "{{ passwords.gitea_admin_password }}"
    email: admin@local

  config:
    APP_NAME: "Gitea: Git with a cup of tea"
    RUN_MODE: prod

    server:
      DOMAIN: {{ network.gitea_hostname or vip_address }}
      ROOT_URL: http://{{ network.gitea_hostname or vip_address }}/
      HTTP_PORT: 3000
      SSH_DOMAIN: {{ worker_ips[0] }}
      SSH_PORT: {{ GITEA_SSH_NODEPORT }}
      SSH_LISTEN_PORT: 22
      LFS_START_SERVER: true

    database:
      DB_TYPE: postgres
      HOST: gitea-db-rw:5432
      NAME: gitea
      USER: gitea
      PASSWD: "{{ passwords.postgresql_password }}"
      SSL_MODE: disable

    cache:
      ENABLED: true
      ADAPTER: redis
      HOST: redis://default:{{ passwords.redis_password | urlencode }}@redis-master:6379/0

    session:
      PROVIDER: redis
      PROVIDER_CONFIG: redis://default:{{ passwords.redis_password | urlencode }}@redis-master:6379/1

    queue:
      TYPE: redis
      CONN_STR: redis://default:{{ passwords.redis_password | urlencode }}@redis-master:6379/2

    security:
      INSTALL_LOCK: true
      SECRET_KEY: "{{ passwords.gitea_admin_password | hash('sha256') }}"
      INTERNAL_TOKEN: "{{ passwords.gitea_admin_password | hash('sha256') }}"

    service:
      DISABLE_REGISTRATION: false
      REQUIRE_SIGNIN_VIEW: false
      REGISTER_EMAIL_CONFIRM: false
      ENABLE_NOTIFY_MAIL: false
      ENABLE_CAPTCHA: false
      DEFAULT_KEEP_EMAIL_PRIVATE: false
      DEFAULT_ALLOW_CREATE_ORGANIZATION: true
      DEFAULT_ENABLE_TIMETRACKING: true

    repository:
      ROOT: /data/git/repositories
      DEFAULT_BRANCH: main

    lfs:
      STORAGE_TYPE: local
      PATH: /data/git/lfs

    log:
      MODE: console
      LEVEL: Info

    # LDAP authentication (school LDAP server)
    # Uncomment and configure as needed
    # authentication:
    #   LDAP:
    #     NAME: SchoolLDAP
    #     SECURITY_PROTOCOL: unencrypted
    #     HOST: {{ LDAP_SERVER }}
    #     PORT: 389
    #     BIND_DN: cn=admin,dc=school,dc=local
    #     BIND_PASSWORD: ldap_password
    #     USER_BASE: ou=users,dc=school,dc=local
    #     ATTRIBUTE_USERNAME: uid
    #     ATTRIBUTE_NAME: givenName
    #     ATTRIBUTE_SURNAME: sn
    #     ATTRIBUTE_MAIL: mail
    #     FILTER: (&(objectClass=inetOrgPerson)(uid=%s))

# Resources - sized for ~90 users (10-15 concurrent)
resources:
  requests:
    memory: "512Mi"
    cpu: "250m"
  limits:
    memory: "2Gi"
    cpu: "2"

# Increased probe timeouts for GlusterFS-backed storage
livenessProbe:
  enabled: true
  initialDelaySeconds: 60
  periodSeconds: 20
  timeoutSeconds: 10
  failureThreshold: 6
readinessProbe:
  enabled: true
  initialDelaySeconds: 30
  periodSeconds: 10
  timeoutSeconds: 10
  failureThreshold: 6
startupProbe:
  enabled: true
  initialDelaySeconds: 30
  periodSeconds: 10
  timeoutSeconds: 10
  failureThreshold: 30

# Pod disruption budget (do NOT use 'enabled' field - directly set minAvailable or maxUnavailable)
podDisruptionBudget:
  minAvailable: 1

# Affinity for spreading pods and scheduling on worker nodes
affinity:
  nodeAffinity:
    requiredDuringSchedulingIgnoredDuringExecution:
      nodeSelectorTerms:
        - matchExpressions:
            - key: node-role.kubernetes.io/control-plane
              operator: DoesNotExist
  podAntiAffinity:
    preferredDuringSchedulingIgnoredDuringExecution:
      - weight: 100
        podAffinityTerm:
          labelSelector:
            matchExpressions:
              - key: app.kubernetes.io/name
                operator: In
                values:
                  - gitea
          topologyKey: kubernetes.io/hostname

# Disable built-in PostgreSQL (using external CloudNativePG)
postgresql:
  enabled: false

postgresql-ha:
  enabled: false

# Disable built-in Redis/Valkey (using external Redis)
redis-cluster:
  enabled: false

valkey:
  enabled: false

valkey-cluster:
  enabled: false
