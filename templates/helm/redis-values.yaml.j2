# Redis Helm values
# Generated by Gitea Infrastructure Deployment
#
# NOTE: Redis uses emptyDir (local node storage) instead of GlusterFS PVCs.
# Rationale: Redis is an in-memory database - network storage defeats the purpose
# and causes liveness probe timeouts. Redis replication provides HA - if a node
# fails, replicas have the data. emptyDir persists across container restarts.

# Architecture
architecture: replication

# Authentication
auth:
  enabled: true
  password: "{{ passwords.redis_password }}"

# Master configuration
master:
  # Disable PVC persistence - Redis uses memory primarily
  # Data survives container restarts via RDB snapshots in emptyDir (chart default)
  persistence:
    enabled: false
  resources:
    requests:
      memory: "256Mi"
      cpu: "100m"
    limits:
      memory: "512Mi"
      cpu: "500m"
  # Increased probe timeouts for school lab network latency
  livenessProbe:
    enabled: true
    initialDelaySeconds: 30
    periodSeconds: 10
    timeoutSeconds: 15
    failureThreshold: 6
  readinessProbe:
    enabled: true
    initialDelaySeconds: 20
    periodSeconds: 10
    timeoutSeconds: 15
    failureThreshold: 6
  # Schedule only on worker nodes
  affinity:
    nodeAffinity:
      requiredDuringSchedulingIgnoredDuringExecution:
        nodeSelectorTerms:
          - matchExpressions:
              - key: node-role.kubernetes.io/control-plane
                operator: DoesNotExist

# Replica configuration
replica:
  replicaCount: {{ applications.redis.replicas - 1 }}
  # Disable PVC persistence - Redis uses memory primarily
  # Data survives container restarts via RDB snapshots in emptyDir (chart default)
  persistence:
    enabled: false
  resources:
    requests:
      memory: "256Mi"
      cpu: "100m"
    limits:
      memory: "512Mi"
      cpu: "500m"
  # Increased probe timeouts for school lab network latency
  livenessProbe:
    enabled: true
    initialDelaySeconds: 30
    periodSeconds: 10
    timeoutSeconds: 15
    failureThreshold: 6
  readinessProbe:
    enabled: true
    initialDelaySeconds: 20
    periodSeconds: 10
    timeoutSeconds: 15
    failureThreshold: 6
  # Schedule only on worker nodes
  affinity:
    nodeAffinity:
      requiredDuringSchedulingIgnoredDuringExecution:
        nodeSelectorTerms:
          - matchExpressions:
              - key: node-role.kubernetes.io/control-plane
                operator: DoesNotExist

# Metrics
metrics:
  enabled: true
  serviceMonitor:
    enabled: true
    namespace: {{ NAMESPACES.monitoring }}

# Common configuration
commonConfiguration: |-
  maxmemory 256mb
  maxmemory-policy allkeys-lru
  save 900 1
  save 300 10
  save 60 10000

# Pod disruption budget
pdb:
  create: true
  minAvailable: 1
