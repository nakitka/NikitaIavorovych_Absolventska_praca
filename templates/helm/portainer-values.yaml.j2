# Portainer Helm values
# Generated by Gitea Infrastructure Deployment

# Image configuration
image:
  repository: portainer/portainer-ce
  tag: latest
  pullPolicy: IfNotPresent

# Replicas
replicaCount: {{ applications.portainer.replicas }}

# Service configuration
service:
  type: ClusterIP
  httpPort: 9000
  edgePort: 8000

# Ingress configuration
ingress:
  enabled: true
  ingressClassName: traefik
  annotations: {}
  hosts:
    - host: {{ "portainer." + network.gitea_hostname.split('.', 1)[1] if network.gitea_hostname and '.' in network.gitea_hostname else "portainer.local" }}
      paths:
        - path: /
          pathType: Prefix
  tls: []

# Persistence
persistence:
  enabled: true
  storageClass: {{ STORAGE_CLASS_NAME }}
  size: {{ applications.portainer.storage_gb }}Gi
  accessMode: ReadWriteOnce

# Resources
resources:
  requests:
    cpu: "100m"
    memory: "128Mi"
  limits:
    cpu: "500m"
    memory: "512Mi"

# Increased probe timeouts for GlusterFS-backed storage
livenessProbe:
  initialDelaySeconds: 30
  periodSeconds: 20
  timeoutSeconds: 10
  failureThreshold: 5
readinessProbe:
  initialDelaySeconds: 20
  periodSeconds: 10
  timeoutSeconds: 10
  failureThreshold: 5

# Schedule on worker nodes
affinity:
  nodeAffinity:
    requiredDuringSchedulingIgnoredDuringExecution:
      nodeSelectorTerms:
        - matchExpressions:
            - key: node-role.kubernetes.io/control-plane
              operator: DoesNotExist

# Service account
serviceAccount:
  name: portainer-sa-clusteradmin

# RBAC
rbac:
  clusterRoleBinding:
    create: true
