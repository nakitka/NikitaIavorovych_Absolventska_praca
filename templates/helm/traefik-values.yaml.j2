# Traefik Helm values
# Generated by Gitea Infrastructure Deployment

# Deployment configuration
deployment:
  replicas: 2

# Service configuration
service:
  type: NodePort

# Port configuration
ports:
  web:
    port: 80
    nodePort: {{ TRAEFIK_HTTP_NODEPORT }}
    expose:
      default: true
    exposedPort: 80
    protocol: TCP
  websecure:
    port: 443
    nodePort: {{ TRAEFIK_HTTPS_NODEPORT }}
    expose:
      default: true
    exposedPort: 443
    protocol: TCP

# Ingress configuration
ingressRoute:
  dashboard:
    enabled: false

# Logs
logs:
  general:
    level: INFO
  access:
    enabled: true

# Pod disruption budget
podDisruptionBudget:
  enabled: true
  minAvailable: 1

# Resources
resources:
  requests:
    cpu: "100m"
    memory: "128Mi"
  limits:
    cpu: "500m"
    memory: "256Mi"

# Node affinity to run on workers
nodeSelector: {}

# Schedule on worker nodes only
affinity:
  nodeAffinity:
    requiredDuringSchedulingIgnoredDuringExecution:
      nodeSelectorTerms:
        - matchExpressions:
            - key: node-role.kubernetes.io/control-plane
              operator: DoesNotExist

# Tolerations
tolerations: []

# Priority class
priorityClassName: ""

# Additional arguments
additionalArguments:
  - "--api.insecure=true"
  - "--accesslog"
  - "--entrypoints.web.address=:80"
  - "--entrypoints.websecure.address=:443"

# Providers
providers:
  kubernetesIngress:
    enabled: true
    publishedService:
      enabled: true
  kubernetesCRD:
    enabled: true
