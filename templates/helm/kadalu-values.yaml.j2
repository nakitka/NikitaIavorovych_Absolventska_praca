# Kadalu Operator Helm values
# Generated by Gitea Infrastructure Deployment

# Operator configuration
operator:
  enabled: true
  image:
    registry: docker.io
    repository: kadalu/kadalu-operator
    tag: latest
    pullPolicy: IfNotPresent

# CSI driver configuration
csi:
  enabled: true
  image:
    registry: docker.io
    repository: kadalu/kadalu-csi
    tag: latest
    pullPolicy: IfNotPresent

# Node plugin (DaemonSet)
nodeplugin:
  enabled: true

# Controller plugin
controllerplugin:
  enabled: true

# Storage class (will be created separately)
storageClass:
  create: false

# Namespace
namespace: kadalu
