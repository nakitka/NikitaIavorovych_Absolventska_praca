# CloudNativePG Operator Helm values
# Generated by Gitea Infrastructure Deployment

# Operator configuration
config:
  create: true

# Controller manager
controllerManager:
  resources:
    requests:
      cpu: "100m"
      memory: "256Mi"
    limits:
      cpu: "500m"
      memory: "512Mi"
  # Schedule on worker nodes
  affinity:
    nodeAffinity:
      requiredDuringSchedulingIgnoredDuringExecution:
        nodeSelectorTerms:
          - matchExpressions:
              - key: node-role.kubernetes.io/control-plane
                operator: DoesNotExist

# Monitoring (disabled - requires Prometheus CRDs)
monitoring:
  podMonitorEnabled: false

# Webhook configuration
webhook:
  port: 9443

# Service account
serviceAccount:
  create: true
