# CloudNativePG PostgreSQL Cluster
# Generated by Gitea Infrastructure Deployment

---
apiVersion: v1
kind: Namespace
metadata:
  name: {{ NAMESPACES.gitea }}

---
apiVersion: v1
kind: Secret
metadata:
  name: gitea-db-secret
  namespace: {{ NAMESPACES.gitea }}
type: kubernetes.io/basic-auth
stringData:
  username: gitea
  password: "{{ passwords.postgresql_password }}"

---
apiVersion: postgresql.cnpg.io/v1
kind: Cluster
metadata:
  name: gitea-db
  namespace: {{ NAMESPACES.gitea }}
spec:
  instances: {{ applications.postgresql.instances }}
  imageName: ghcr.io/cloudnative-pg/postgresql:16

  storage:
    storageClass: {{ STORAGE_CLASS_NAME }}
    size: {{ applications.postgresql.storage_per_instance_gb }}Gi

  bootstrap:
    initdb:
      database: gitea
      owner: gitea
      secret:
        name: gitea-db-secret
      postInitSQL:
        - CREATE EXTENSION IF NOT EXISTS pg_trgm;

  # PostgreSQL tuning for ~90 users (10-15 concurrent)
  postgresql:
    parameters:
      max_connections: "200"
      shared_buffers: "1GB"
      effective_cache_size: "2GB"
      maintenance_work_mem: "256MB"
      work_mem: "16MB"
      checkpoint_completion_target: "0.9"
      wal_buffers: "32MB"
      default_statistics_target: "100"
      random_page_cost: "1.1"
      effective_io_concurrency: "200"
      min_wal_size: "1GB"
      max_wal_size: "4GB"
      # Keep WAL files longer so replicas can catch up after restarts
      wal_keep_size: "4GB"

  # Resources sized for ~90 users
  resources:
    requests:
      memory: "1Gi"
      cpu: "500m"
    limits:
      memory: "4Gi"
      cpu: "2"

  # Increased delays for GlusterFS-backed storage
  startDelay: 120
  stopDelay: 60
  switchoverDelay: 60

  # Extended probe timeouts for GlusterFS latency - increased to reduce false failovers
  probes:
    liveness:
      initialDelaySeconds: 90
      periodSeconds: 20
      timeoutSeconds: 60
      failureThreshold: 20
    readiness:
      initialDelaySeconds: 45
      periodSeconds: 15
      timeoutSeconds: 60
      failureThreshold: 15

  # Replication slots prevent WAL deletion until replica catches up
  # This prevents "requested WAL segment has already been removed" errors
  replicationSlots:
    highAvailability:
      enabled: true
    updateInterval: 30

  monitoring:
    enablePodMonitor: true

  affinity:
    podAntiAffinityType: preferred
    # Schedule only on worker nodes
    nodeAffinity:
      requiredDuringSchedulingIgnoredDuringExecution:
        nodeSelectorTerms:
          - matchExpressions:
              - key: node-role.kubernetes.io/control-plane
                operator: DoesNotExist

  backup:
    barmanObjectStore: null

  enableSuperuserAccess: true
